{
  "tests": [
    {
      "name": "Register new user",
      "method": "POST",
      "path": "/",
      "body": {
        "action": "register",
        "username": "testuser_auto",
        "email": "testauto@example.com",
        "password": "password123",
        "display_name": "Тест"
      },
      "expectedStatus": 201,
      "expectedBody": { "token": "string" },
      "bodyMatcher": "partial"
    },
    {
      "name": "Login with email",
      "method": "POST",
      "path": "/",
      "body": {
        "action": "login",
        "login": "testauto@example.com",
        "password": "password123"
      },
      "expectedStatus": 200,
      "expectedBody": { "token": "string" },
      "bodyMatcher": "partial"
    },
    {
      "name": "Login wrong password",
      "method": "POST",
      "path": "/",
      "body": {
        "action": "login",
        "login": "testauto@example.com",
        "password": "wrongpassword"
      },
      "expectedStatus": 401,
      "expectedBody": { "error": "string" },
      "bodyMatcher": "partial"
    }
  ]
}